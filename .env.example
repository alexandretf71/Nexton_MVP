# LLM provider: "mock" (default, no API key needed) or "anthropic"
LLM_PROVIDER=mock

# Required only when LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=

# Required only when LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL_ID=gpt-4o

# Anthropic model to use
MODEL_ID=claude-sonnet-4-6

# FastAPI server
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=false

# URL the Streamlit UI uses to reach the FastAPI backend
UI_API_BASE_URL=http://localhost:8000

# Port Streamlit runs on — must match the --server.port flag below
# The API uses this to configure CORS; change both together if you pick a different port.
UI_ORIGIN=http://localhost:8502
